{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx electron-vite:*)",
      "Bash(dig:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"waiting\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"needs-approval\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"needs-approval\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"waiting\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"processing\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hid=\"$CLAUDE_HARNESS_ID\"; [ -z \"$hid\" ] && exit 0; mkdir -p /tmp/harness-status; echo \"{\\\"status\\\":\\\"processing\\\",\\\"ts\\\":$(date +%s)}\" > /tmp/harness-status/$hid.json'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

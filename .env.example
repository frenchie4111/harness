# Notarization credentials for `npm run dist`.
# Copy this file to .env and fill in your values.
# .env is gitignored.

# Your Apple ID email
APPLE_ID=

# App-specific password from https://appleid.apple.com/account/manage
# Format: abcd-efgh-ijkl-mnop
APPLE_APP_SPECIFIC_PASSWORD=

# Your Apple Developer Team ID (visible in the cert name, e.g. M7Y6TPCQ63)
APPLE_TEAM_ID=
